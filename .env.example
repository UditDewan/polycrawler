# Copy to .env (gitignored) and fill in. Never commit real values.

# NVIDIA hosted inference (Phase 2+) — build.nvidia.com
NVIDIA_API_KEY=

# Reddit API (Phase 1 social collector). Create a "script" app at
# https://www.reddit.com/prefs/apps . Without these, the reddit source skips gracefully.
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=polycrawler/0.1 by u/yourname
